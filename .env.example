# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# DATABASE_URL: pooled connection (PgBouncer) — used by the app at runtime
# DIRECT_URL:   direct connection — used by Prisma migrations only
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Supabase Auth & Storage
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Transactional email (invites, password resets)
# Optional in dev — if unset, invite emails are logged to the server console
# with the full accept-invite URL so you can click through locally.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Getyn Campaigns <no-reply@getyn.app>

# -----------------------------------------------------------------------------
# Background jobs (Phase 2)
# REDIS_URL: BullMQ + ioredis TCP URL. Upstash free tier is recommended — one
#   URL works for both local dev and production. Use the `rediss://` variant.
#   If unset in dev, the worker exits cleanly and `pnpm dev` keeps the web app
#   running — so you can work on non-import features without Redis.
# WORKER_IMPORTS_CONCURRENCY: how many CSV import jobs the worker processes
#   in parallel. Default 2. Tune based on Railway instance size in prod.
# -----------------------------------------------------------------------------
REDIS_URL=
WORKER_IMPORTS_CONCURRENCY=2

# -----------------------------------------------------------------------------
# Application-layer encryption (Phase 4 M1)
#
# AES-256-GCM key for protecting tenant credentials at rest (WABA tokens
# in Phase 4, SMS provider creds in Phase 6). Generate with:
#   openssl rand -base64 32
#
# ENCRYPTION_KEY is version 1; future rotations land as ENCRYPTION_KEY_V2,
# ENCRYPTION_KEY_V3, ... Set ACTIVE_KEY_VERSION to direct new writes at
# the chosen version. Old keys must remain present until every ciphertext
# at that version is re-encrypted (rotation backfill). Deleting a key
# while ciphertexts at that version still exist is unrecoverable.
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=
ACTIVE_KEY_VERSION=1

# -----------------------------------------------------------------------------
# WhatsApp Business — Meta API (Phase 4 M3+)
#
# In Phase 4 each tenant brings their own WABA + system-user access token
# via the manual connect flow at /t/[slug]/settings/channels/whatsapp.
# Tokens are stored encrypted via @getyn/crypto with tenantId as AD.
#
# META_APP_SECRET: server-wide app secret used by the webhook receiver
#   (Phase 4 M9) to verify X-Hub-Signature-256. Get it from your Meta
#   developer app dashboard → App Settings → Basic. Same secret signs
#   all webhooks regardless of which tenant is the recipient — Meta
#   ties signatures to the app, not the WABA.
# WHATSAPP_WEBHOOK_VERIFY_TOKEN: arbitrary string you choose; configure
#   the same value in Meta's webhook setup form. Used for the GET
#   verification handshake.
# META_APP_ID: your Meta App ID (numeric). Phase 4 M11 (Embedded Signup)
#   uses this in the FB.login config.
# META_CONFIG_ID: Embedded Signup configuration ID from Meta. Phase 4 M11.
# -----------------------------------------------------------------------------
META_APP_SECRET=
META_APP_ID=
META_CONFIG_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Public mirrors — Embedded Signup needs the App ID + Config ID in the
# browser bundle so FB.login can target your Meta app + your WhatsApp
# product config. Set both client + server values to the same string.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=

# -----------------------------------------------------------------------------
# AI features (Phase 4 M7+; Phase 5 expands)
#
# Powers the "Draft with AI" button on the WhatsApp template editor and
# (Phase 5) email subject lines, inbox reply suggestions, segment naming.
# Without this key, the AI features render as disabled — the rest of the
# app is unaffected.
#
# Get a key at console.anthropic.com → API Keys.
# Cost ~ $0.003 per template generation. Per-tenant rate-limit is 10/hour.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Observability (all optional in dev)
#
# Sentry — Phase 4 M0. Two separate projects: one for the web app (Next.js
# server + browser bundle), one for the worker (Node). Splitting them keeps
# alert rules focused (e.g. "worker job failure rate" makes no sense on web)
# and lets us scale plan tiers independently. NEXT_PUBLIC_SENTRY_DSN_WEB
# is the same value as SENTRY_DSN_WEB but exposed to the browser bundle —
# Next.js requires the NEXT_PUBLIC_ prefix to inline it client-side.
#
# SENTRY_ENVIRONMENT: 'development' | 'preview' | 'production'.
# SENTRY_RELEASE: optional — if set, errors get tagged with the release.
#   Recommended: set to the git short SHA in CI.
# SENTRY_AUTH_TOKEN / SENTRY_ORG / SENTRY_PROJECT_WEB: only needed in CI to
#   upload source maps. Local builds work without them.
# -----------------------------------------------------------------------------
SENTRY_DSN_WEB=
NEXT_PUBLIC_SENTRY_DSN_WEB=
SENTRY_DSN_WORKER=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT_WEB=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
