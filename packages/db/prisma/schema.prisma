// Getyn Campaigns schema
//
// Phase 1: User, Tenant, Membership, Invitation (foundational identity/tenancy)
// Phase 2: Contact, Tag, ContactTag, CustomField, Segment, ImportJob,
//          SuppressionEntry, ContactEvent (audience management)
// Phase 3: SendingDomain, Campaign, EmailCampaign, EmailTemplate, CampaignSend,
//          CampaignEvent, TrackingLink, TenantSendingPolicy (email builder + send pipeline)
// Phase 4: WhatsAppAccount, WhatsAppPhoneNumber, WhatsAppTemplate,
//          WhatsAppCampaign, WhatsAppCampaignSend, WhatsAppConversation,
//          WhatsAppMessage, WhatsAppWebhookEvent, Asset, AiGeneration
// Stripe billing belongs to later phases.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------------
// Enums — Phase 1
// ------------------------------------------------------------------

// Phase 1 coarse tier label, kept for the legacy `Tenant.legacyPlanTier`
// column. Renamed from `Plan` in Phase 5.5 M0 because the unprefixed
// `Plan` is now the local plan catalog model. Pure display copy; no
// behaviour depends on the value.
enum LegacyPlanTier {
  TRIAL
  STARTER
  GROWTH
  PRO
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// ------------------------------------------------------------------
// Enums — Phase 2 (audience & contacts)
// ------------------------------------------------------------------

enum ContactSource {
  MANUAL
  IMPORT
  API
  FORM
}

// Per-contact per-channel subscribe / unsubscribe state. Renamed from
// `SubscriptionStatus` in Phase 5.5 M0 because that name now belongs
// to the tenant ↔ plan Subscription model (TRIALING/ACTIVE/CANCELED…).
// Field name `Contact.emailStatus / smsStatus / whatsappStatus`
// unchanged.
enum ContactChannelStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  PENDING
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum ImportDedupeStrategy {
  EMAIL
  PHONE
  EMAIL_OR_PHONE
}

enum Channel {
  EMAIL
  SMS
  WHATSAPP
}

enum SuppressionReason {
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  MANUAL
  IMPORT
}

// ------------------------------------------------------------------
// Enums — Phase 3 (email builder, sending, campaign analytics)
// ------------------------------------------------------------------

enum SendingDomainStatus {
  PENDING
  VERIFIED
  FAILED
  SUSPENDED
}

enum CampaignType {
  EMAIL
  WHATSAPP
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  FAILED
  CANCELED
}

enum EmailTemplateCategory {
  NEWSLETTER
  ANNOUNCEMENT
  PROMOTIONAL
  TRANSACTIONAL
  EVENT
  WELCOME
  OTHER
}

enum CampaignSendStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
  SUPPRESSED
}

enum AbVariant {
  A
  B
}

enum CampaignEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  FAILED
}

// Full event vocabulary defined now. Phase 2 only emits the manual/import
// subset (CREATED, UPDATED, IMPORTED, TAG_ADDED, TAG_REMOVED, SUBSCRIBED,
// UNSUBSCRIBED, BOUNCED, COMPLAINED). The send-pipeline values
// (EMAIL_*, SMS_*, WHATSAPP_*) are reserved for Phase 3+ so the segment
// rule builder can expose them as selectable fields today with a
// "No data yet" badge.
enum ContactEventType {
  CREATED
  UPDATED
  IMPORTED
  TAG_ADDED
  TAG_REMOVED
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  EMAIL_SENT
  EMAIL_DELIVERED
  EMAIL_OPENED
  EMAIL_CLICKED
  SMS_SENT
  SMS_DELIVERED
  WHATSAPP_SENT
  WHATSAPP_DELIVERED
  WHATSAPP_READ
  // Phase 4 additions — webhook ingestion + inbox flagging
  WHATSAPP_FAILED
  WHATSAPP_REPLIED
}

// ------------------------------------------------------------------
// Models — Phase 1
// ------------------------------------------------------------------

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String?
  avatarUrl      String?
  // Phase 1: required when Supabase was the only auth provider.
  // Phase 5 M1: now optional — Auth0-only users (SSO via G-Suite) have
  // no Supabase row, only an auth0UserId. Existing rows keep their
  // value; SSO-linked users have both populated.
  supabaseUserId String?      @unique
  // Phase 5 M1
  auth0UserId    String?      @unique
  authProvider   AuthProvider @default(SUPABASE)
  lastSsoSyncAt  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships           Membership[]
  sentInvites           Invitation[]    @relation("InvitedBy")
  segmentsCreated       Segment[]       @relation("SegmentsCreatedBy")
  importsCreated        ImportJob[]     @relation("ImportsCreatedBy")
  campaignsCreated      Campaign[]      @relation("CampaignsCreatedBy")
  emailTemplatesCreated EmailTemplate[] @relation("EmailTemplatesCreatedBy")
  emailVerifierRuns     EmailVerifierCleanupRun[] @relation("EmailVerifierRunsBy")

  // Phase 4 backrelations
  whatsAppTemplatesCreated      WhatsAppTemplate[]     @relation("WhatsAppTemplatesCreatedBy")
  assetsUploaded                Asset[]                @relation("AssetsUploadedBy")
  aiGenerations                 AiGeneration[]
  whatsAppMessagesSent          WhatsAppMessage[]      @relation("WhatsAppMessagesSentBy")
  whatsAppConversationsAssigned WhatsAppConversation[] @relation("WhatsAppConversationsAssignedTo")

  // Phase 5 M2 — per-device session store. Lets us list signed-in
  // devices in user settings + revoke remote sessions.
  sessions UserSession[]

  // Phase 7 — AI Campaign Agents
  agentConversationsStarted AgentConversation[] @relation("AgentConversationsStartedBy")

  // Phase 5.5 — upgrade requests submitted by this user (their tenant).
  planUpgradeRequests PlanUpgradeRequest[] @relation("PlanUpgradeRequestedBy")

  @@index([email])
}

model Tenant {
  id                 String             @id @default(cuid())
  slug               String             @unique
  name               String
  // Phase 1 coarse plan enum. DEPRECATED in Phase 5.5: source of
  // truth is now Subscription.status. Column kept to avoid a
  // backfill migration; no code reads it after Phase 5.5 M0.
  // Drop in a future phase once we're certain it's unused.
  legacyPlanTier     LegacyPlanTier     @default(TRIAL) @map("plan")
  billingStatus      BillingStatus      @default(TRIALING)
  trialEndsAt        DateTime?
  settings           Json               @default("{}")
  // Phase 5 M1 — G-Suite identity mapping. Tenants provisioned via
  // SSO have gSuiteTenantId set; existing direct tenants (the demo +
  // anything signed up pre-SSO) leave it null.
  gSuiteTenantId     String?            @unique
  gSuiteOrgName      String?
  gSuiteSyncedAt     DateTime?
  provisioningSource ProvisioningSource @default(DIRECT)
  // Phase 3 — used by the email send pipeline
  postalAddress      String? // CAN-SPAM-required physical address; M6 blocks sending if null
  companyDisplayName String? // shown in email footer
  defaultFromName    String? // pre-fills the campaign wizard "from name" field
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  memberships        Membership[]
  invitations        Invitation[]
  contacts           Contact[]
  tags               Tag[]
  customFields       CustomField[]
  segments           Segment[]
  importJobs         ImportJob[]
  suppressionEntries SuppressionEntry[]
  contactEvents      ContactEvent[]
  // Phase 3
  sendingDomains     SendingDomain[]
  emailTemplates     EmailTemplate[]
  campaigns          Campaign[]
  campaignSends      CampaignSend[]
  campaignEvents     CampaignEvent[]
  trackingLinks      TrackingLink[]
  sendingPolicy      TenantSendingPolicy?

  // Phase 4
  whatsAppAccount       WhatsAppAccount?
  whatsAppPhoneNumbers  WhatsAppPhoneNumber[]
  whatsAppTemplates     WhatsAppTemplate[]
  whatsAppCampaignSends WhatsAppCampaignSend[]
  whatsAppConversations WhatsAppConversation[]
  whatsAppMessages      WhatsAppMessage[]
  whatsAppWebhookEvents WhatsAppWebhookEvent[]
  assets                Asset[]
  aiGenerations         AiGeneration[]

  // Phase 5 M1+M3 — G-Suite identity + billing
  // Phase 5.5 — local plan + override + upgrade-request backrelations.
  // Replaces the Phase 5 M1 `billingSubscription BillingSubscription?`.
  subscription        Subscription?
  limitOverrides      TenantLimitOverride[]
  planUpgradeRequests PlanUpgradeRequest[]
  gSuiteWebhookEvents GSuiteWebhookEvent[]

  // Phase 7 — AI Campaign Agents
  brandProfile        TenantBrandProfile?
  agentConversations  AgentConversation[]
  agentAttachments    AgentAttachment[]
  proposedImportPlans ProposedImportPlan[]
  emailVerifierRuns   EmailVerifierCleanupRun[]

  @@index([slug])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Invitation {
  id              String    @id @default(cuid())
  tenantId        String
  email           String
  role            Role
  token           String    @unique
  invitedByUserId String
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@index([token])
}

// ------------------------------------------------------------------
// Models — Phase 2
// ------------------------------------------------------------------

// A person we can market to. Tenant-scoped.
//
// At least one of `email` / `phone` must be set — enforced in the app layer
// (Zod + tRPC mutations) rather than a DB check so we can return nicer
// errors and keep raw SQL inserts flexible for the seed script.
//
// `customFields` is a free-form JSON bag keyed by `CustomField.key`.
// Writes must validate keys against the tenant's CustomField registry
// (app-layer enforcement).
//
// Soft delete via `deletedAt`. Partial unique indexes on (tenantId, email)
// and (tenantId, phone) — see `0002_phase2_audience/migration.sql` — exclude
// soft-deleted rows so a deleted email can be re-added later.
model Contact {
  id             String               @id @default(cuid())
  tenantId       String
  email          String? // lowercase-normalized at write time
  phone          String? // E.164-normalized at write time
  firstName      String?
  lastName       String?
  customFields   Json                 @default("{}")
  source         ContactSource        @default(MANUAL)
  emailStatus    ContactChannelStatus @default(SUBSCRIBED)
  smsStatus      ContactChannelStatus @default(SUBSCRIBED)
  whatsappStatus ContactChannelStatus @default(SUBSCRIBED)
  language       String               @default("en")
  timezone       String?
  deletedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tags                  ContactTag[]
  events                ContactEvent[]
  // Phase 3 — every send to this contact records here
  campaignSends         CampaignSend[]
  // Phase 4 — WhatsApp campaign sends + inbox conversations
  whatsAppCampaignSends WhatsAppCampaignSend[]
  whatsAppConversations WhatsAppConversation[]
  // Partial unique indexes on (tenantId, email) and (tenantId, phone) are
  // added via raw SQL in the migration because Prisma 5.22 cannot declare
  // partial indexes in the schema.

  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, emailStatus])
  @@index([tenantId, smsStatus])
  @@index([tenantId, whatsappStatus])
  @@index([tenantId, deletedAt])
}

model Tag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String // "#RRGGBB"
  createdAt DateTime @default(now())

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

// Defines the schema for `Contact.customFields`. `key` is a slug (e.g.
// "plan_tier", "lifetime_value") unique per tenant. Adding a new field is
// non-destructive. Removing a field strips that key from all contacts'
// `customFields` JSON (app-layer, with a confirmation step). `type` is
// immutable after creation — enforced in the app's update handler.
model CustomField {
  id        String          @id @default(cuid())
  tenantId  String
  key       String
  label     String
  type      CustomFieldType
  options   Json? // { choices: string[] } for SELECT
  createdAt DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Segment {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  rules           Json // validated via `segmentRulesSchema` (packages/types)
  cachedCount     Int?
  cachedCountAt   DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("SegmentsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  // Phase 3 — campaigns target a segment
  campaigns Campaign[]

  @@index([tenantId, createdAt])
}

model ImportJob {
  id                    String               @id @default(cuid())
  tenantId              String
  status                ImportJobStatus      @default(PENDING)
  fileName              String
  storagePath           String // "imports/{tenantId}/{id}.csv" in Supabase Storage
  totalRows             Int?
  processedRows         Int                  @default(0)
  successRows           Int                  @default(0)
  /// Of successRows, how many landed as updates on a pre-existing
  /// contact (matched by the dedupeBy strategy). The remainder is
  /// new inserts. UI surfaces this as "X new + Y updated" so users
  /// can sanity-check a re-import.
  updatedRows           Int                  @default(0)
  errorRows             Int                  @default(0)
  errors                Json                 @default("[]") // capped at 100 entries + { truncated: boolean }
  mapping               Json // { [csvColumn]: { kind: 'field'|'custom_field'|'skip', field?: string, customFieldId?: string } }
  tagIds                String[]
  defaultEmailStatus    ContactChannelStatus @default(SUBSCRIBED)
  defaultSmsStatus      ContactChannelStatus @default(SUBSCRIBED)
  defaultWhatsappStatus ContactChannelStatus @default(SUBSCRIBED)
  dedupeBy              ImportDedupeStrategy @default(EMAIL_OR_PHONE)
  createdByUserId       String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime             @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("ImportsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Phase 7.1 — Audience Agent that produced this job (if any).
  producedFromPlan ProposedImportPlan?

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

// Per-tenant block list keyed on (channel, value). Contacts whose status
// flips to UNSUBSCRIBED/BOUNCED/COMPLAINED get a matching entry auto-created
// at the app layer. The send pipeline (Phase 3) must check this table
// before every send.
//
// Removing an entry here does NOT auto-resubscribe the associated contact —
// that's a separate explicit action (keeps the semantics safe under
// accidental bulk-delete).
model SuppressionEntry {
  id        String            @id @default(cuid())
  tenantId  String
  channel   Channel
  value     String // email: lowercased; phone: E.164
  reason    SuppressionReason
  metadata  Json              @default("{}")
  createdAt DateTime          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel, value])
  @@index([tenantId, channel])
}

model ContactEvent {
  id         String           @id @default(cuid())
  tenantId   String
  contactId  String
  type       ContactEventType
  metadata   Json             @default("{}")
  occurredAt DateTime         @default(now())
  createdAt  DateTime         @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId, occurredAt(sort: Desc)])
  @@index([tenantId, type, occurredAt(sort: Desc)])
  @@index([tenantId, occurredAt(sort: Desc)])
}

// ------------------------------------------------------------------
// Models — Phase 3 (email builder, sending, campaign analytics)
// ------------------------------------------------------------------

// A tenant's Resend-verified email sending domain (e.g. "mail.acme.com").
// Created via the tRPC `sendingDomain.create` mutation, which calls Resend's
// domain-create API and stores the returned `resendDomainId` + DNS records.
// Verification is polled via `sendingDomain.verify` (button in the UI) and
// also by a BullMQ repeatable job in apps/worker every 30 minutes for
// PENDING domains.
model SendingDomain {
  id             String              @id @default(cuid())
  tenantId       String
  domain         String
  resendDomainId String?
  status         SendingDomainStatus @default(PENDING)
  verifiedAt     DateTime?
  // Array of { type, name, value, status, priority? } objects — Zod-validated
  // by `sendingDomainSchema` in @getyn/types.
  dnsRecords     Json                @default("[]")
  lastCheckedAt  DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns EmailCampaign[]

  @@unique([tenantId, domain])
  @@index([tenantId, status])
}

// Top-level campaign entity. Phase 3 only implements `type = EMAIL`; the
// enum is widened now so Phase 4 (WhatsApp) and Phase 5 (SMS) reuse this
// row shape without a schema change.
//
// Status transitions:
//   DRAFT  -> SCHEDULED (campaign.schedule)
//   DRAFT  -> SENDING   (campaign.sendNow)
//   SCHEDULED -> SENDING (worker fires at scheduledAt)
//   SENDING -> SENT     (worker marks complete)
//   SCHEDULED -> CANCELED (user cancels before sentAt)
//   SENDING -> PAUSED   (auto on tenant suspension)
//   any -> FAILED       (unrecoverable infra error)
model Campaign {
  id              String         @id @default(cuid())
  tenantId        String
  type            CampaignType   @default(EMAIL)
  name            String
  status          CampaignStatus @default(DRAFT)
  segmentId       String
  scheduledAt     DateTime?
  sentAt          DateTime?
  // Tenant timezone snapshotted at create time, so editing the tenant's TZ
  // later doesn't shift an already-scheduled campaign.
  timezone        String         @default("UTC")
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segment               Segment                @relation(fields: [segmentId], references: [id], onDelete: Restrict)
  createdBy             User?                  @relation("CampaignsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  emailCampaign         EmailCampaign?
  // Phase 4 — 1:1 sidecar for type=WHATSAPP campaigns
  whatsAppCampaign      WhatsAppCampaign?
  whatsAppCampaignSends WhatsAppCampaignSend[]
  sends                 CampaignSend[]
  events                CampaignEvent[]
  trackingLinks         TrackingLink[]

  // Phase 7 — when a campaign was produced by an agent
  sourceAgentConversation AgentConversation?

  @@index([tenantId, status, scheduledAt])
  @@index([tenantId, createdAt])
}

// 1:1 sidecar of Campaign carrying email-specific fields (subject, design,
// rendered HTML, A/B config). Has no own tenantId — RLS joins through
// Campaign, mirroring the ContactTag pattern from Phase 2.
//
// `renderedHtml` is set when status moves out of DRAFT and is immutable
// after that (enforced in tRPC + a defensive trigger added in the
// migration). Mid-flight edits would mean recipients in the same campaign
// got different content.
model EmailCampaign {
  id              String  @id @default(cuid())
  campaignId      String  @unique
  subject         String
  previewText     String?
  fromName        String
  fromEmail       String
  replyTo         String?
  sendingDomainId String?
  // Unlayer's design payload — the single source of truth for the editor.
  designJson      Json
  // Flattened HTML at send time. Text columns to support large emails.
  renderedHtml    String? @db.Text
  // Auto-generated plaintext alternative via html-to-text. Required for
  // RFC-compliant multipart/alternative emails.
  renderedText    String? @db.Text
  // Zod-validated by `abTestSchema` in @getyn/types. Null when A/B is off.
  abTest          Json?
  templateId      String?

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sendingDomain SendingDomain? @relation(fields: [sendingDomainId], references: [id], onDelete: SetNull)
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

// System templates have `tenantId = null` and are read-only to every tenant.
// Tenant-owned templates have `tenantId` set and follow the standard RLS
// pattern. The migration adds two RLS policies (one for each case).
model EmailTemplate {
  id              String                @id @default(cuid())
  tenantId        String? // NULL = system template
  name            String
  description     String?
  category        EmailTemplateCategory @default(OTHER)
  thumbnailUrl    String?
  designJson      Json
  createdByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant    Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("EmailTemplatesCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  campaigns EmailCampaign[]

  @@index([tenantId, category])
  @@index([tenantId, createdAt])
}

// One row per (campaign, recipient). The unit of dispatch + tracking.
// Created in bulk by the `prepare-campaign` BullMQ job; updated by the
// `dispatch-batch` worker (status = SENT) and webhook handler
// (DELIVERED/OPENED/CLICKED/BOUNCED/COMPLAINED).
//
// `email` is a snapshot at queue time — we never look up the contact
// again after queueing. If the contact's email changes mid-send, the
// already-queued sends still go to the original address.
//
// `messageId` is Resend's globally unique id; webhook lookups use it.
model CampaignSend {
  id           String             @id @default(cuid())
  tenantId     String
  campaignId   String
  contactId    String
  email        String
  messageId    String?            @unique
  status       CampaignSendStatus @default(QUEUED)
  abVariant    AbVariant?
  sentAt       DateTime?
  lastEventAt  DateTime?
  errorMessage String?

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events   CampaignEvent[]

  @@index([tenantId, campaignId, status])
  @@index([tenantId, contactId])
}

// Append-only time-series of every send outcome. The webhook handler
// inserts here; analytics queries this table for the time-series chart
// (real-time numbers come from CampaignSend.status aggregates instead —
// see M8).
//
// `metadata` is JSON, validated per-type by Zod schemas in @getyn/types
// (`campaignEventMetadataSchemas`). Stored unstructured for forward
// compatibility with new Resend event fields.
model CampaignEvent {
  id             String            @id @default(cuid())
  tenantId       String
  campaignSendId String
  // Direct denormalized link to Campaign for analytics queries — avoids a
  // JOIN through CampaignSend on every dashboard render. The cascade
  // through campaignSendId already handles real deletion; this FK is just
  // for direct lookups, hence `SetNull` to avoid double-cascade conflict.
  campaignId     String?
  type           CampaignEventType
  metadata       Json              @default("{}")
  occurredAt     DateTime          @default(now())
  createdAt      DateTime          @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignSend CampaignSend @relation(fields: [campaignSendId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId, campaignSendId, occurredAt(sort: Desc)])
  @@index([tenantId, type, occurredAt(sort: Desc)])
  @@index([tenantId, campaignId, occurredAt(sort: Desc)])
}

// Short-link table powering /r/{slug} click tracking. Link-rewriting
// happens at dispatch time: the renderer scans the email HTML, replaces
// every `<a href>` with `/r/{slug}` after creating a TrackingLink row.
//
// `slug` is 8-char base62 (~218T combos), generated via nanoid.
// Collision-on-insert retry up to 3x in code.
//
// `clickCount` is denormalized for fast top-links queries; the source of
// truth is CampaignEvent rows of type CLICKED.
model TrackingLink {
  id          String   @id @default(cuid())
  tenantId    String
  campaignId  String
  originalUrl String
  slug        String   @unique
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([tenantId, campaignId])
}

// Per-tenant deliverability guardrails + plan-driven limits. One row per
// tenant, auto-created by the `0003_phase3_email` migration backfill.
//
// `currentDailyCount` resets via a BullMQ repeatable job at 00:00 UTC.
// `cached*30d` aggregates are updated incrementally by the webhook
// handler on every bounce/complaint event, and recomputed from raw
// CampaignEvent rows by an hourly drift-correction job (see M6 pushback
// item #4 in the kickoff). `dispatch-batch` reads the cached values
// only — never aggregates raw events at send time.
//
// `suspendedAt` is set automatically when a rate exceeds threshold; the
// UI shows a banner; new sends are rejected until OWNER manually clears
// the suspension via the runbook (see apps/worker/README.md).
model TenantSendingPolicy {
  id                     String    @id @default(cuid())
  tenantId               String    @unique
  // Defaults overridden in the migration backfill based on plan.
  dailySendLimit         Int       @default(200)
  complaintRateThreshold Float     @default(0.003)
  bounceRateThreshold    Float     @default(0.05)
  currentDailyCount      Int       @default(0)
  lastResetAt            DateTime  @default(now())
  cachedComplaintRate30d Float     @default(0)
  cachedBounceRate30d    Float     @default(0)
  cachedSendCount30d     Int       @default(0)
  cachedRatesUpdatedAt   DateTime  @default(now())
  suspendedAt            DateTime?
  suspensionReason       String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ==================================================================
// Phase 4 — WhatsApp Business
// ==================================================================
//
// BYOC model: each tenant brings their own WhatsApp Business Account
// (WABA). We store an encrypted system-user access token (see
// @getyn/crypto). Templates are authored in our UI, submitted to Meta,
// status polled back. Outbound campaign status uses 2-minute Graph API
// polling; inbound messages use webhooks with a 5-minute poll fallback.
//
// Core dual-write rule: outbound campaign messages create BOTH a
// WhatsAppCampaignSend (analytics source of truth) and a
// WhatsAppMessage (inbox source of truth) in the dispatch transaction.
// Status updates from polling/webhooks update both by metaMessageId.
// They are siblings — no FK between them — linked by string match.

// ------------------------------------------------------------------
// Enums — Phase 4
// ------------------------------------------------------------------

enum WAStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  SUSPENDED
}

enum WAQualityRating {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

// Meta's messaging tier — determines unique-recipient cap per 24h.
// Newly registered numbers start at TIER_50; Meta auto-promotes based
// on quality + volume.
enum WAMessagingTier {
  TIER_50
  TIER_250
  TIER_1K
  TIER_10K
  TIER_100K
  TIER_UNLIMITED
}

enum WADisplayPhoneStatus {
  CONNECTED
  PENDING_REVIEW
  DISCONNECTED
  FLAGGED
}

enum WATemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum WATemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

// Per-message pricing category from Meta. Different from template
// category — Meta may reclassify based on actual content/intent.
enum WAPricingCategory {
  AUTHENTICATION
  MARKETING
  UTILITY
  SERVICE
}

enum WASendStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  SUPPRESSED
}

enum WAMessageDirection {
  INBOUND
  OUTBOUND
}

enum WAMessageType {
  TEXT
  TEMPLATE
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  STICKER
  LOCATION
  CONTACT
  INTERACTIVE_BUTTON
  INTERACTIVE_LIST
  REACTION
  UNSUPPORTED
}

enum WAConversationStatus {
  OPEN
  CLOSED
}

// ------------------------------------------------------------------
// Models — Phase 4
// ------------------------------------------------------------------

// One WABA per tenant in MVP (see kickoff #4 pushback). The unique
// constraint on tenantId enforces this. Multi-WABA per tenant
// (multi-brand companies) is a future migration.
//
// `accessTokenEncrypted` is a Json column carrying the @getyn/crypto
// EncryptedField shape: { ciphertext, iv, authTag, keyVersion }.
// Encrypted with tenantId as associated data so a row stolen out of
// tenant A's account into tenant B fails authentication.
model WhatsAppAccount {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  wabaId               String // Meta's Business Account ID
  displayName          String
  status               WAStatus  @default(PENDING)
  connectedAt          DateTime?
  disconnectedAt       DateTime?
  accessTokenEncrypted Json // EncryptedField from @getyn/crypto, AD=tenantId
  tokenExpiresAt       DateTime? // null for system-user tokens that don't expire
  appId                String // Meta App ID used for connection (M3 manual or M11 embedded)
  metadata             Json      @default("{}") // business verification status, country, currency
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumbers  WhatsAppPhoneNumber[]
  templates     WhatsAppTemplate[]
  campaigns     WhatsAppCampaign[]
  conversations WhatsAppConversation[]

  @@index([tenantId])
  @@index([wabaId])
}

// One per phone number registered to the WABA. A tenant typically has
// one (e.g. customer-support hotline) but Meta allows up to 25.
//
// `currentTier24hUsage` + `tier24hWindowResetAt` are best-effort local
// counters refreshed by the wa-phone-refresh cron from Meta's API
// (M4). The 24h window starts at first send, NOT at midnight UTC.
model WhatsAppPhoneNumber {
  id                       String               @id @default(cuid())
  tenantId                 String
  whatsAppAccountId        String
  phoneNumberId            String // Meta's phone_number_id
  phoneNumber              String // E.164 display, e.g. +14155551234
  verifiedName             String
  qualityRating            WAQualityRating      @default(UNKNOWN)
  messagingTier            WAMessagingTier      @default(TIER_50)
  currentTier24hUsage      Int                  @default(0)
  tier24hWindowResetAt     DateTime?
  displayPhoneNumberStatus WADisplayPhoneStatus @default(PENDING_REVIEW)
  pinSetAt                 DateTime? // 2FA PIN required for sending
  metadata                 Json                 @default("{}")
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount        @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  campaigns       WhatsAppCampaign[]
  conversations   WhatsAppConversation[]

  @@unique([tenantId, phoneNumberId])
  @@index([whatsAppAccountId])
}

// In-app authored OR synced from Meta. `metaTemplateId` is null for
// drafts not yet submitted; sync (M5) backfills it when Meta reports
// the template under the same (name, language). Soft-deleted via
// `deletedAt`; the partial unique index in 0004 migration excludes
// deleted rows so a tenant can recreate same-name templates.
//
// `components` is a Json array matching Meta's API exactly — see
// templateComponentsSchema in @getyn/types. We submit it directly.
model WhatsAppTemplate {
  id                String             @id @default(cuid())
  tenantId          String
  whatsAppAccountId String
  metaTemplateId    String? // null until submitted to Meta
  name              String // slug, lowercase + underscores per Meta
  language          String // e.g. en_US, hi, es
  category          WATemplateCategory
  status            WATemplateStatus   @default(DRAFT)
  rejectionReason   String?            @db.Text
  components        Json // TemplateComponent[] — see @getyn/types
  qualityRating     WAQualityRating    @default(UNKNOWN)
  lastSyncedAt      DateTime?
  submittedAt       DateTime?
  approvedAt        DateTime?
  createdByUserId   String?
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount    @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  createdBy       User?              @relation("WhatsAppTemplatesCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  campaigns       WhatsAppCampaign[]
  messages        WhatsAppMessage[]

  // Partial unique index (whatsAppAccountId, name, language) WHERE
  // deletedAt IS NULL — added in 0004 migration (Prisma can't express
  // partial uniques in the schema).
  @@index([tenantId, status])
  @@index([whatsAppAccountId, status])
}

// 1:1 sidecar of Campaign for type=WHATSAPP. Mirrors EmailCampaign.
// `templateVariables` is a Json array of { type, value | merge_tag }
// resolved per-recipient at dispatch time.
model WhatsAppCampaign {
  id                 String  @id @default(cuid())
  campaignId         String  @unique
  whatsAppAccountId  String
  phoneNumberId      String
  templateId         String
  templateLanguage   String
  templateVariables  Json // resolved per-recipient at dispatch
  headerMediaAssetId String?

  campaign         Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  whatsAppAccount  WhatsAppAccount     @relation(fields: [whatsAppAccountId], references: [id], onDelete: Restrict)
  phoneNumber      WhatsAppPhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Restrict)
  template         WhatsAppTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  headerMediaAsset Asset?              @relation(fields: [headerMediaAssetId], references: [id], onDelete: SetNull)
}

// Per-recipient send record. Mirrors CampaignSend (Phase 3) for
// analytics. The dispatch handler creates this AND a WhatsAppMessage
// row atomically so the inbox renders campaign messages alongside
// free-form replies.
model WhatsAppCampaignSend {
  id              String             @id @default(cuid())
  tenantId        String
  campaignId      String
  contactId       String
  phone           String // E.164 snapshot at queue time
  metaMessageId   String? // null until dispatched; unique per tenant once set
  status          WASendStatus       @default(QUEUED)
  pricingCategory WAPricingCategory? // Meta's per-message pricing classification
  conversationId  String? // Meta's conversation ID (24h window grouping)
  errorCode       String?
  errorMessage    String?            @db.Text
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  lastEventAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, metaMessageId])
  @@index([tenantId, campaignId, status])
  @@index([tenantId, status, createdAt])
}

// Inbox conversation. Identified per tenant by (phoneNumberId, contactPhone).
// `serviceWindowExpiresAt` is set/extended ONLY on inbound messages
// (24h forward); outbound replies do NOT extend it (this is Meta's rule).
// `unreadCount` updated atomically via SQL increment, never read-modify-write.
model WhatsAppConversation {
  id                     String               @id @default(cuid())
  tenantId               String
  whatsAppAccountId      String
  phoneNumberId          String
  contactId              String? // null for inbound from unknown numbers, until matched
  contactPhone           String // E.164
  lastInboundAt          DateTime?
  lastOutboundAt         DateTime?
  lastMessageAt          DateTime             @default(now())
  lastMessagePreview     String               @default("") @db.Text
  unreadCount            Int                  @default(0)
  assignedToUserId       String?
  serviceWindowExpiresAt DateTime? // null = window closed; only template messages allowed
  status                 WAConversationStatus @default(OPEN)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount     @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  phoneNumber     WhatsAppPhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  contact         Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo      User?               @relation("WhatsAppConversationsAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages        WhatsAppMessage[]

  @@unique([tenantId, phoneNumberId, contactPhone])
  @@index([tenantId, lastMessageAt])
  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, assignedToUserId, lastMessageAt])
}

// Every inbound + outbound message in the inbox. Outbound campaign
// messages also land here (dual write with WhatsAppCampaignSend).
//
// `metaMessageId` is unique per tenant — used by the webhook /
// poll-status handlers to dedupe and update status. `replyToMessageId`
// is a self-FK for quoted replies.
model WhatsAppMessage {
  id                String             @id @default(cuid())
  tenantId          String
  conversationId    String
  direction         WAMessageDirection
  metaMessageId     String? // unique per tenant once set
  type              WAMessageType
  body              String?            @db.Text // text body; caption for media; null for non-text
  mediaAssetId      String? // resolved Asset for media messages
  mediaMetaId       String? // Meta's media id, used for delayed download
  templateId        String? // for outbound TEMPLATE messages
  templateVariables Json? // resolved variables at send time
  status            WASendStatus       @default(QUEUED)
  errorCode         String?
  errorMessage      String?            @db.Text
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  sentByUserId      String? // for free-form replies sent from inbox UI
  replyToMessageId  String? // self-FK
  metadata          Json               @default("{}")
  createdAt         DateTime           @default(now())

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  template     WhatsAppTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  mediaAsset   Asset?               @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  sentBy       User?                @relation("WhatsAppMessagesSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)
  replyTo      WhatsAppMessage?     @relation("WhatsAppMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies      WhatsAppMessage[]    @relation("WhatsAppMessageReplies")

  @@index([conversationId, createdAt])
  @@index([tenantId, metaMessageId])
}

// Raw event log for idempotency + debugging. The webhook receiver
// upserts on `dedupeKey` (computed from event kind + metaMessageId +
// status, see kickoff pushback #1). Successful processing sets
// `processedAt`; failure stamps `processError` for retry.
model WhatsAppWebhookEvent {
  id            String    @id @default(cuid())
  tenantId      String? // null until matched (e.g. unknown WABA hits us)
  phoneNumberId String? // null until matched
  eventType     String // 'inbound' | 'status:sent' | 'status:delivered' | etc.
  dedupeKey     String    @unique
  rawPayload    Json
  processedAt   DateTime?
  processError  String?   @db.Text
  receivedAt    DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, receivedAt])
  @@index([eventType, processedAt])
}

// Generic media table. Used by template media headers, inbox media
// messages, and future asset-bearing features. Storage path lives
// under tenants/<tenantId>/wa-assets/<id>.<ext> in the wa-assets
// bucket (private, signed URLs only).
model Asset {
  id               String   @id @default(cuid())
  tenantId         String
  fileName         String
  mimeType         String
  sizeBytes        Int
  storagePath      String // tenants/<tenantId>/wa-assets/<id>.<ext>
  mediaMetaId      String? // Meta's media id, populated after upload to Meta
  uploadedByUserId String?
  createdAt        DateTime @default(now())

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy        User?              @relation("AssetsUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  templateMessages  WhatsAppMessage[]
  campaignsAsHeader WhatsAppCampaign[]

  // Phase 7 — brand-profile logos referencing assets
  brandProfilesAsLogo TenantBrandProfile[] @relation("BrandProfileLogo")

  // Phase 7.1 — back-refs from agent attachments + import plans
  agentAttachments    AgentAttachment[]
  proposedImportPlans ProposedImportPlan[]

  @@index([tenantId, createdAt])
}

// AI generation audit log. Phase 4 M7 introduces the first AI feature
// (template drafting). Phase 5 will expand this with per-feature
// rate limits / cost rollups.
model AiGeneration {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  feature    String // 'wa_template_draft' for now; enum in Phase 5
  prompt     String   @db.Text
  response   String   @db.Text
  tokensUsed Int
  cost       Decimal  @db.Decimal(10, 4) // USD; sub-cent precision for token-cost rollups
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, feature, createdAt])
}

// ==================================================================
// Phase 5 — G-Suite integration (M1, M3, M7)
// ==================================================================

enum AuthProvider {
  SUPABASE
  AUTH0
}

enum ProvisioningSource {
  DIRECT
  G_SUITE
}

// ------------------------------------------------------------------
// Plan catalog — mirror of G-Suite's plans. Tenant-agnostic.
// Service-role read-only; nothing in Campaigns mutates these except
// the M3 plan-sync helper (and the seed script).
// ------------------------------------------------------------------

// ------------------------------------------------------------------
// Plans — local plans managed in admin. Phase 5.5 replaces the
// Phase 5 M1 BillingPlan/BillingPlanFeature/BillingSubscription
// tables (renamed without the prefix) because Campaigns no longer
// mirrors G-Suite billing — plans are local-only.
// ------------------------------------------------------------------

enum PlanMetric {
  CONTACTS
  EMAILS_PER_MONTH
  WA_MESSAGES_PER_MONTH
  SMS_SEGMENTS_PER_MONTH
  AI_CREDITS_PER_MONTH
  CUSTOM_SENDING_DOMAINS
  USER_SEATS
  // Phase 7 — AI Campaign Agents conversation cap.
  AI_AGENT_CONVERSATIONS_PER_MONTH
}

model Plan {
  id                   String   @id @default(cuid())
  slug                 String   @unique
  name                 String
  description          String?  @db.Text
  // Display-only. Campaigns doesn't bill — these surface in admin +
  // tenant subscription pages as "what your plan costs" UI copy.
  priceMonthlyCents    Int?
  priceYearlyCents     Int?
  currency             String   @default("USD")
  isArchived           Boolean  @default(false)
  // Enforced "at most one default" via partial unique index in the
  // migration: CREATE UNIQUE INDEX ON "Plan"("isDefault") WHERE
  // "isDefault" = true.
  isDefault            Boolean  @default(false)
  metadata             Json     @default("{}")
  // Audit-trail only — not a FK; deleted staff users don't cascade-
  // delete plans.
  createdByStaffUserId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  features                     PlanFeature[]
  subscriptions                Subscription[]
  // Default-plan back-relation (AppSettings.defaultPlanId).
  appSettings                  AppSettings[]
  currentPlanUpgradeRequests   PlanUpgradeRequest[] @relation("currentPlanForUpgradeRequest")
  requestedPlanUpgradeRequests PlanUpgradeRequest[] @relation("requestedPlanForUpgradeRequest")

  @@index([isArchived, isDefault])
}

model PlanFeature {
  id                String     @id @default(cuid())
  planId            String
  metric            PlanMetric
  // -1 marks unlimited.
  included          Int        @default(0)
  // Informational only — Campaigns doesn't bill overages today.
  overageCentsPer1k Int?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, metric])
}

// ------------------------------------------------------------------
// Subscription — tenant ↔ plan assignment, one per tenant.
// Phase 5.5 replaces BillingSubscription. deriveTenantState reads
// from this table; the legacy Tenant.billingStatus column is kept
// for backcompat (no longer read) and will be dropped in a future
// migration once no code references it.
// ------------------------------------------------------------------

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  planId                String
  status                SubscriptionStatus @default(ACTIVE)
  // Audit-trail only. null = backfill from migration OR auto-assign
  // on tenant creation (when AppSettings.defaultPlanAutoAssign=true).
  assignedByStaffUserId String?
  assignedAt            DateTime           @default(now())
  // Display-only since Campaigns doesn't bill. Drives the period-
  // reset cron: when currentPeriodEnd < now we advance both by 1
  // month (UTC) and reset period-bound counters. null = rolling
  // calendar month (defaults to 1st-of-month UTC).
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAt              DateTime?
  metadata              Json               @default("{}")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([currentPeriodEnd]) // for the period-reset cron
}

// ------------------------------------------------------------------
// TenantLimitOverride — per-tenant overrides on top of plan limits.
// resolveTenantLimits() merges these on top of PlanFeature rows.
// ------------------------------------------------------------------

model TenantLimitOverride {
  id                   String     @id @default(cuid())
  tenantId             String
  metric               PlanMetric
  included             Int // -1 = unlimited
  reason               String     @db.Text
  expiresAt            DateTime? // null = permanent
  createdByStaffUserId String?
  createdAt            DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, metric, expiresAt])
}

// ------------------------------------------------------------------
// PlanUpgradeRequest — tenant-initiated upgrade flow.
// ------------------------------------------------------------------

enum PlanUpgradeRequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model PlanUpgradeRequest {
  id                    String                   @id @default(cuid())
  tenantId              String
  requestedByUserId     String
  // Snapshot at request time. SetNull because deleting an archived
  // plan shouldn't break the audit trail.
  currentPlanId         String?
  requestedPlanId       String
  status                PlanUpgradeRequestStatus @default(PENDING)
  reason                String?                  @db.Text
  reviewedByStaffUserId String?
  reviewedAt            DateTime?
  reviewerNote          String?                  @db.Text
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy   User   @relation("PlanUpgradeRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  currentPlan   Plan?  @relation("currentPlanForUpgradeRequest", fields: [currentPlanId], references: [id], onDelete: SetNull)
  requestedPlan Plan   @relation("requestedPlanForUpgradeRequest", fields: [requestedPlanId], references: [id], onDelete: Restrict)

  @@index([status, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
}

// ------------------------------------------------------------------
// AppSettings — singleton config row, enforced via CHECK constraint
// (id = 'singleton') in the migration SQL.
// ------------------------------------------------------------------

model AppSettings {
  id                    String   @id @default("singleton")
  defaultPlanId         String?
  defaultPlanAutoAssign Boolean  @default(false)
  allowUpgradeRequests  Boolean  @default(true)
  updatedByStaffUserId  String?
  updatedAt             DateTime @updatedAt

  defaultPlan Plan? @relation(fields: [defaultPlanId], references: [id], onDelete: SetNull)
}

// ------------------------------------------------------------------
// G-Suite webhook ingestion (audit + idempotency).
// dedupeKey approach mirrors WhatsAppWebhookEvent (Phase 4 M9).
// ------------------------------------------------------------------

model GSuiteWebhookEvent {
  id            String    @id @default(cuid())
  gSuiteEventId String    @unique
  eventType     String
  tenantId      String?
  rawPayload    Json
  processedAt   DateTime?
  processError  String?   @db.Text
  receivedAt    DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([eventType, receivedAt])
  @@index([tenantId])
}

// ------------------------------------------------------------------
// Phase 5 M7 — staff (Getyn internal). Distinct from Tenant users:
// staff have no Membership rows and can't reach /t/[slug]/* surfaces
// through the staff session. The /admin/* surface checks this table.
// ------------------------------------------------------------------

enum StaffRole {
  SUPPORT
  SUPPORT_ADMIN
}

model StaffUser {
  id        String    @id @default(cuid())
  email     String    @unique
  role      StaffRole
  createdAt DateTime  @default(now())
  // StaffUser.id of the inviter. Null for bootstrapped INITIAL_STAFF_EMAILS.
  createdBy String?

  auditLogs StaffAuditLog[]

  @@index([role])
}

model StaffAuditLog {
  id             String   @id @default(cuid())
  staffUserId    String
  // Snapshot — survives StaffUser deletion so the audit log isn't
  // weakened by tombstoning the actor row.
  staffEmail     String
  action         String
  targetTenantId String?
  targetEntityId String?
  beforeSnapshot Json?
  afterSnapshot  Json?
  reason         String?  @db.Text
  ipAddress      String?
  userAgent      String?  @db.Text
  createdAt      DateTime @default(now())

  staffUser StaffUser @relation(fields: [staffUserId], references: [id], onDelete: Cascade)

  @@index([staffUserId, createdAt])
  @@index([targetTenantId, createdAt])
  @@index([action, createdAt])
}

// ==================================================================
// Phase 5 M2 — per-device session store.
//
// Each issued auth cookie (Auth0 OR Supabase fallback) corresponds
// to a row here. The cookie carries `sessionToken`; verification
// looks the row up + checks `revokedAt IS NULL` + not expired.
//
// Why a session table when JWT-style cookies are stateless? Two
// reasons:
//   1. Revoke remote devices in real time. A stateless cookie
//      can't be invalidated until it expires; a session-store row
//      can be revokedAt-stamped and refused on the next request.
//   2. List "your active sessions" in user settings — devices,
//      locations, last-active. Hard to derive from a stateless
//      cookie.
//
// Schema is provider-agnostic: stores `provider=AUTH0` or
// `provider=SUPABASE`. Supabase sessions are tracked best-effort
// (we don't own Supabase's cookie lifecycle, but we record what
// we issue so the listing UI is consistent).
// ==================================================================

model UserSession {
  id           String       @id @default(cuid())
  userId       String
  // Random opaque token embedded in the cookie payload. Used for
  // lookup; never exposed in URLs or surfaces other than the cookie.
  sessionToken String       @unique
  provider     AuthProvider
  deviceLabel  String? // best-effort from user agent
  ipAddress    String?
  userAgent    String?      @db.Text
  issuedAt     DateTime     @default(now())
  expiresAt    DateTime
  lastSeenAt   DateTime     @default(now())
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

// ==================================================================
// Phase 5.6 — Platform-level integrations + system email templates +
// site branding. All admin-only (RLS denies authenticated tenant
// traffic; access flows through withAdminContext()).
// ==================================================================

enum IntegrationTestStatus {
  UNTESTED
  OK
  FAILED
}

enum SystemEmailTemplateCategory {
  TRANSACTIONAL
  NOTIFICATION
  MARKETING
}

/// One row per platform integration (whatsapp_meta, smtp_default,
/// resend, railway_worker, twilio, msg91...). Non-secret config is
/// stored as JSON for forward compatibility; `secrets` carries an
/// AES-256-GCM envelope from @getyn/crypto with AD =
/// "integration:{provider}" so ciphertexts can't be swapped between
/// rows.
///
/// Resolution helpers (`getWhatsAppCredentials()` etc.) prefer this
/// row when `enabled=true`, falling back to env vars otherwise so
/// the app stays functional during migration.
model IntegrationCredential {
  id                       String                @id @default(cuid())
  provider                 String                @unique
  displayName              String
  enabled                  Boolean               @default(false)
  config                   Json                  @default("{}")
  secrets                  Json?
  lastUpdatedByStaffUserId String?
  lastTestedAt             DateTime?
  lastTestStatus           IntegrationTestStatus @default(UNTESTED)
  lastTestError            String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@index([enabled])
}

/// System notification templates (welcome, password reset, invite,
/// plan-upgrade-*, impersonation notice, etc.). isSystem=true rows
/// are edit-only — no delete in the admin UI.
///
/// `variables` is a JSON string[] of substitution names available to
/// the template author; the renderer (Phase 5.6 M3) accepts a
/// superset and ignores unknowns.
model SystemEmailTemplate {
  id                       String                      @id @default(cuid())
  slug                     String                      @unique
  name                     String
  description              String?                     @db.Text
  subject                  String
  bodyHtml                 String                      @db.Text
  bodyText                 String                      @db.Text
  variables                Json                        @default("[]")
  category                 SystemEmailTemplateCategory
  isSystem                 Boolean                     @default(true)
  enabled                  Boolean                     @default(true)
  lastUpdatedByStaffUserId String?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  @@index([category])
  @@index([enabled])
}

/// Singleton (id='singleton' CHECK-enforced in migration). All
/// branding fields are nullable — `getSiteBranding()` substitutes
/// hard-coded defaults so the app never breaks on a clean install.
/// Per-tenant overrides are deferred (would land as
/// TenantBrandingOverride).
model SiteBrandingSettings {
  id                         String   @id @default("singleton")
  appName                    String   @default("Getyn Campaigns")
  defaultSidebarLogoLightUrl String?
  defaultSidebarLogoDarkUrl  String?
  loginPageLogoUrl           String?
  faviconUrl                 String?
  primaryColor               String?
  accentColor                String?
  loginPageTagline           String?
  footerText                 String?
  customCss                  String?  @db.Text
  updatedByStaffUserId       String?
  updatedAt                  DateTime @updatedAt
}

// ==================================================================
// Phase 7 — AI Campaign Agents.
//
// TenantBrandProfile (1:1 per tenant) carries the brand context every
// agent reads at conversation start. AgentConversation is one chat
// session that produces at most one DRAFT campaign. AgentMessage
// stores every turn (user / assistant / tool-call / tool-result /
// system) for resume + audit. EmailBlockTemplate is the global vetted
// library Claude composes designs from.
// ==================================================================

enum VoiceTone {
  PROFESSIONAL
  FRIENDLY
  CASUAL
  PLAYFUL
  AUTHORITATIVE
  EMPATHETIC
}

enum AgentChannel {
  EMAIL
  WHATSAPP
}

enum AgentConversationStatus {
  ACTIVE
  COMPLETED_DRAFT_CREATED
  ABANDONED
  FAILED
}

enum AgentMessageRole {
  USER
  ASSISTANT
  TOOL_CALL
  TOOL_RESULT
  SYSTEM
}

enum EmailBlockCategory {
  HERO
  CONTENT
  MEDIA
  CTA
  FOOTER
  DIVIDER
  SOCIAL
}

/// One per tenant. Filled by the user from /t/[slug]/settings/brand,
/// read by every agent conversation at start. `completedAt` is null
/// until the user runs the "Save & complete" path; agent entry points
/// block until it's set.
model TenantBrandProfile {
  id                      String    @id @default(cuid())
  tenantId                String    @unique
  brandName               String
  brandTagline            String?
  brandDescription        String    @db.Text
  primaryColor            String // #RRGGBB
  secondaryColor          String?
  accentColor             String?
  logoAssetId             String?
  logoUrl                 String?
  voiceTone               VoiceTone @default(FRIENDLY)
  writingStyle            String?   @db.Text
  industry                String?
  targetAudience          String?   @db.Text
  dosAndDonts             String?   @db.Text
  signatureBlock          String?   @db.Text
  socialLinks             Json      @default("[]")
  unsubscribeFooterCustom String?   @db.Text
  completedAt             DateTime?
  updatedByUserId         String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoAsset Asset? @relation("BrandProfileLogo", fields: [logoAssetId], references: [id], onDelete: SetNull)
}

/// One row per chat session that produces a draft campaign. Status
/// progresses ACTIVE → (COMPLETED_DRAFT_CREATED | ABANDONED | FAILED).
/// `producedCampaignId` is unique so a draft maps back to exactly one
/// source conversation.
model AgentConversation {
  id                 String                  @id @default(cuid())
  tenantId           String
  createdByUserId    String
  /// Which agent surface produced this conversation. Phase 7 had only
  /// CAMPAIGN_EMAIL + CAMPAIGN_WHATSAPP; Phase 7.1 adds AUDIENCE.
  agentKind          AgentKind               @default(CAMPAIGN_EMAIL)
  /// Channel is only meaningful for CAMPAIGN_* kinds. AUDIENCE rows
  /// MUST have channel = NULL. Invariant is enforced at write time in
  /// the tRPC layer (no DB CHECK constraint — kept light so a future
  /// agent kind doesn't need a migration to add to the allowed set).
  channel            AgentChannel?
  status             AgentConversationStatus @default(ACTIVE)
  goal               String?
  producedCampaignId String?                 @unique
  conversationState  Json                    @default("{}")
  tokensUsed         Int                     @default(0)
  costCents          Int                     @default(0)
  title              String?
  lastMessageAt      DateTime                @default(now())
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy        User           @relation("AgentConversationsStartedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  producedCampaign Campaign?      @relation(fields: [producedCampaignId], references: [id], onDelete: SetNull)
  messages         AgentMessage[]

  // Phase 7.1
  attachments        AgentConversationAttachment[]
  proposedImportPlan ProposedImportPlan?

  @@index([tenantId, status, lastMessageAt(sort: Desc)])
  @@index([createdByUserId, lastMessageAt(sort: Desc)])
  @@index([tenantId, agentKind, lastMessageAt(sort: Desc)])
}

/// Every turn of every conversation. `tenantId` denormalised so the
/// RLS policy doesn't need to JOIN through AgentConversation on every
/// read (matches the CampaignSend / Contact pattern).
model AgentMessage {
  id             String           @id @default(cuid())
  conversationId String
  tenantId       String
  role           AgentMessageRole
  content        String?          @db.Text
  toolName       String?
  toolInput      Json?
  toolOutput     Json?
  tokensInput    Int?
  tokensOutput   Int?
  errorMessage   String?
  createdAt      DateTime         @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Phase 7.1 — first time an attachment is referenced in this message
  referencingAttachments AgentConversationAttachment[]

  @@index([conversationId, createdAt])
}

/// Global library of vetted email block templates. Seeded by the
/// 0010 migration with 12 starter blocks; not user-editable in Phase 7.
/// `unlayerDesignJsonTemplate` carries the real Unlayer JSON with
/// `{{placeholder}}` tokens that the composer substitutes from
/// agent-provided content + brand defaults.
model EmailBlockTemplate {
  id                        String             @id @default(cuid())
  slug                      String             @unique
  name                      String
  description               String             @db.Text
  category                  EmailBlockCategory
  previewImageUrl           String?
  unlayerDesignJsonTemplate Json
  placeholders              Json               @default("[]")
  compatibleAfter           String[]           @default([])
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@index([category])
}

// =====================================================================
// Phase 7.1 — Attachments + Audience Agent
// =====================================================================

/// Which agent surface produced this conversation. The campaign-side
/// kinds carry a non-null `AgentConversation.channel`; AUDIENCE rows
/// always have channel = NULL.
enum AgentKind {
  CAMPAIGN_EMAIL
  CAMPAIGN_WHATSAPP
  AUDIENCE
}

/// Coarse type used to route the parser pipeline + the summarizer
/// prompt template. Each upload is classified once at insert time
/// from the MIME type (after magic-byte verification).
enum AttachmentType {
  IMAGE
  PDF
  SPREADSHEET
  DOCUMENT
}

/// Audience Agent's import plan, before user approval.
enum ProposedImportPlanStatus {
  DRAFT
  APPROVED
  REJECTED
  IMPORTED
  FAILED
}

/// One row per file uploaded into an agent conversation. The underlying
/// Storage object + Asset row are wrapped here so cleanup semantics are
/// scoped to agent use only — the Asset library used by email blocks /
/// WhatsApp media is untouched.
///
/// Lifecycle: created with `expiresAt = createdAt + 30 days`; bumped to
/// NULL when the attachment is referenced in a finalized plan (campaign
/// draft or ProposedImportPlan). The daily cleanup cron deletes rows
/// whose `expiresAt < now` and whose conversation is no longer active.
model AgentAttachment {
  id                   String         @id @default(cuid())
  tenantId             String
  /// Underlying storage row. We do NOT cascade — the cleanup worker
  /// deletes the Storage object first, then this row, then the Asset,
  /// in that order, so a partial failure never orphans either side.
  assetId              String
  attachmentType       AttachmentType
  /// Structured representation written by the attachment-parse worker.
  /// Shape varies by type — see worker handler for the canonical
  /// shapes (spreadsheet: { columns, rowCount, sampleRows,
  /// columnTypeGuesses }; pdf: { pageCount, textContent, pageImages };
  /// docx: { text, wordCount, headings, truncated }; image: { width,
  /// height, thumbnailPath }).
  parsedContent        Json?
  parsedAt             DateTime?
  /// Claude-generated 2–5 sentence summary, included in conversation
  /// system context. Capped at $0.05 per attachment; falls back to a
  /// deterministic stub if Claude is unavailable.
  aiSummary            String?        @db.Text
  aiSummaryGeneratedAt DateTime?
  aiSummaryModel       String?
  /// Phase 7.2 — structured visual style cues for IMAGE attachments.
  /// Lazily populated the first time `generate_image_for_block` uses
  /// this attachment as a reference, then cached so subsequent
  /// generations don't re-pay the vision call. Shape:
  /// { colors: string[], mood: string, composition: string, subject: string }.
  visualStyleCues      Json?
  /// 30-day default; NULL means "pinned — referenced in a finalized
  /// plan, do not auto-delete".
  expiresAt            DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  tenant        Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset         Asset                         @relation(fields: [assetId], references: [id], onDelete: Restrict)
  conversations AgentConversationAttachment[]

  @@unique([tenantId, assetId])
  @@index([tenantId, expiresAt])
  @@index([tenantId, createdAt])
}

/// Join table — an attachment can be referenced in more than one
/// conversation (rare but legal: user uploads brand guidelines once,
/// agent reuses across campaigns). `referencedAtMessageId` records the
/// first message that introduced the attachment into the conversation;
/// the UI uses it to render the attachment inline at that point in the
/// transcript.
model AgentConversationAttachment {
  id                    String   @id @default(cuid())
  tenantId              String
  conversationId        String
  agentAttachmentId     String
  referencedAtMessageId String?
  createdAt             DateTime @default(now())

  conversation        AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachment          AgentAttachment   @relation(fields: [agentAttachmentId], references: [id], onDelete: Cascade)
  referencedAtMessage AgentMessage?     @relation(fields: [referencedAtMessageId], references: [id], onDelete: SetNull)

  @@unique([conversationId, agentAttachmentId])
  @@index([tenantId, conversationId])
}

/// Audience Agent's output before user approval. Exactly one per
/// conversation. Status DRAFT until the user clicks Approve in the
/// review card; flips to APPROVED, which creates an ImportJob via the
/// existing Phase 2 worker and stamps `producedImportJobId`. We never
/// write to Contact directly from the agent — handoff goes through the
/// existing import pipeline so dedupe / RLS / progress all match.
model ProposedImportPlan {
  id                  String                   @id @default(cuid())
  tenantId            String
  conversationId      String                   @unique
  sourceAssetId       String
  /// { [csvColumn]: { kind: 'field', field: 'email' } | { kind: 'custom_field', key: 'state' } | { kind: 'skip' } }
  columnMapping       Json                     @default("{}")
  /// Array of { column, operator, value } expressions the agent built
  /// during the conversation (e.g. State IN [California, Texas]).
  filters             Json                     @default("[]")
  dedupeStrategy      ImportDedupeStrategy     @default(EMAIL)
  tagsToApply         String[]                 @default([])
  /// Channel-specific opt-in status applied to all imported contacts.
  /// Audience Agent prompt forces explicit user confirmation before
  /// setting SUBSCRIBED.
  defaultEmailStatus  ContactChannelStatus     @default(PENDING)
  estimatedRows       Int?
  /// 10 sample rows showing how they'd be imported — fed to the
  /// review card.
  previewRows         Json                     @default("[]")
  /// Array of { severity: 'warning'|'error', message, affectedRows? }.
  validationIssues    Json                     @default("[]")
  status              ProposedImportPlanStatus @default(DRAFT)
  approvedAt          DateTime?
  producedImportJobId String?                  @unique
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation      AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sourceAsset       Asset             @relation(fields: [sourceAssetId], references: [id], onDelete: Restrict)
  producedImportJob ImportJob?        @relation(fields: [producedImportJobId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
}

/// Email Verifier cleanup run history. One row per bulk
/// mark-as-unsubscribed action; the UI surfaces these as a list with
/// drill-down so users can re-view which addresses were affected.
///
/// affectedContactIds is a TEXT[] — simplest possible storage. A
/// 100k-row cleanup lands at ~2.5MB which Postgres handles fine.
/// If we ever cross that we'd promote to a join table.
model EmailVerifierCleanupRun {
  id                 String   @id @default(cuid())
  tenantId           String
  runByUserId        String?
  /// FlagCategory values: INVALID_SYNTAX, ALREADY_BOUNCED,
  /// TYPO_SUSPICIOUS, DISPOSABLE, ROLE_BASED, DEAD_DOMAIN.
  categories         String[]
  totalCount         Int      @default(0)
  /// { [FlagCategory]: number }. Not a strict enum-keyed object
  /// because Json doesn't enforce it; the verifier service writes
  /// canonical keys.
  countByCategory    Json     @default("{}")
  affectedContactIds String[]
  createdAt          DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runBy  User?  @relation("EmailVerifierRunsBy", fields: [runByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
}
