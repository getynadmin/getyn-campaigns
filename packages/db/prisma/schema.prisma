// Getyn Campaigns schema
//
// Phase 1: User, Tenant, Membership, Invitation (foundational identity/tenancy)
// Phase 2: Contact, Tag, ContactTag, CustomField, Segment, ImportJob,
//          SuppressionEntry, ContactEvent (audience management)
// Phase 3: SendingDomain, Campaign, EmailCampaign, EmailTemplate, CampaignSend,
//          CampaignEvent, TrackingLink, TenantSendingPolicy (email builder + send pipeline)
// Phase 4: WhatsAppAccount, WhatsAppPhoneNumber, WhatsAppTemplate,
//          WhatsAppCampaign, WhatsAppCampaignSend, WhatsAppConversation,
//          WhatsAppMessage, WhatsAppWebhookEvent, Asset, AiGeneration
// Stripe billing belongs to later phases.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------------------
// Enums — Phase 1
// ------------------------------------------------------------------

enum Plan {
  TRIAL
  STARTER
  GROWTH
  PRO
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum Role {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// ------------------------------------------------------------------
// Enums — Phase 2 (audience & contacts)
// ------------------------------------------------------------------

enum ContactSource {
  MANUAL
  IMPORT
  API
  FORM
}

enum SubscriptionStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  PENDING
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum ImportDedupeStrategy {
  EMAIL
  PHONE
  EMAIL_OR_PHONE
}

enum Channel {
  EMAIL
  SMS
  WHATSAPP
}

enum SuppressionReason {
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  MANUAL
  IMPORT
}

// ------------------------------------------------------------------
// Enums — Phase 3 (email builder, sending, campaign analytics)
// ------------------------------------------------------------------

enum SendingDomainStatus {
  PENDING
  VERIFIED
  FAILED
  SUSPENDED
}

enum CampaignType {
  EMAIL
  WHATSAPP
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PAUSED
  FAILED
  CANCELED
}

enum EmailTemplateCategory {
  NEWSLETTER
  ANNOUNCEMENT
  PROMOTIONAL
  TRANSACTIONAL
  EVENT
  WELCOME
  OTHER
}

enum CampaignSendStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  FAILED
  SUPPRESSED
}

enum AbVariant {
  A
  B
}

enum CampaignEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  FAILED
}

// Full event vocabulary defined now. Phase 2 only emits the manual/import
// subset (CREATED, UPDATED, IMPORTED, TAG_ADDED, TAG_REMOVED, SUBSCRIBED,
// UNSUBSCRIBED, BOUNCED, COMPLAINED). The send-pipeline values
// (EMAIL_*, SMS_*, WHATSAPP_*) are reserved for Phase 3+ so the segment
// rule builder can expose them as selectable fields today with a
// "No data yet" badge.
enum ContactEventType {
  CREATED
  UPDATED
  IMPORTED
  TAG_ADDED
  TAG_REMOVED
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  EMAIL_SENT
  EMAIL_DELIVERED
  EMAIL_OPENED
  EMAIL_CLICKED
  SMS_SENT
  SMS_DELIVERED
  WHATSAPP_SENT
  WHATSAPP_DELIVERED
  WHATSAPP_READ
  // Phase 4 additions — webhook ingestion + inbox flagging
  WHATSAPP_FAILED
  WHATSAPP_REPLIED
}

// ------------------------------------------------------------------
// Models — Phase 1
// ------------------------------------------------------------------

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  avatarUrl      String?
  supabaseUserId String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships           Membership[]
  sentInvites           Invitation[]    @relation("InvitedBy")
  segmentsCreated       Segment[]       @relation("SegmentsCreatedBy")
  importsCreated        ImportJob[]     @relation("ImportsCreatedBy")
  campaignsCreated      Campaign[]      @relation("CampaignsCreatedBy")
  emailTemplatesCreated EmailTemplate[] @relation("EmailTemplatesCreatedBy")

  // Phase 4 backrelations
  whatsAppTemplatesCreated WhatsAppTemplate[]     @relation("WhatsAppTemplatesCreatedBy")
  assetsUploaded           Asset[]                @relation("AssetsUploadedBy")
  aiGenerations            AiGeneration[]
  whatsAppMessagesSent     WhatsAppMessage[]      @relation("WhatsAppMessagesSentBy")
  whatsAppConversationsAssigned WhatsAppConversation[] @relation("WhatsAppConversationsAssignedTo")

  @@index([email])
}

model Tenant {
  id                 String        @id @default(cuid())
  slug               String        @unique
  name               String
  plan               Plan          @default(TRIAL)
  billingStatus      BillingStatus @default(TRIALING)
  trialEndsAt        DateTime?
  settings           Json          @default("{}")
  // Phase 3 — used by the email send pipeline
  postalAddress      String? // CAN-SPAM-required physical address; M6 blocks sending if null
  companyDisplayName String? // shown in email footer
  defaultFromName    String? // pre-fills the campaign wizard "from name" field
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  memberships        Membership[]
  invitations        Invitation[]
  contacts           Contact[]
  tags               Tag[]
  customFields       CustomField[]
  segments           Segment[]
  importJobs         ImportJob[]
  suppressionEntries SuppressionEntry[]
  contactEvents      ContactEvent[]
  // Phase 3
  sendingDomains     SendingDomain[]
  emailTemplates     EmailTemplate[]
  campaigns          Campaign[]
  campaignSends      CampaignSend[]
  campaignEvents     CampaignEvent[]
  trackingLinks      TrackingLink[]
  sendingPolicy      TenantSendingPolicy?

  // Phase 4
  whatsAppAccount       WhatsAppAccount?
  whatsAppPhoneNumbers  WhatsAppPhoneNumber[]
  whatsAppTemplates     WhatsAppTemplate[]
  whatsAppCampaignSends WhatsAppCampaignSend[]
  whatsAppConversations WhatsAppConversation[]
  whatsAppMessages      WhatsAppMessage[]
  whatsAppWebhookEvents WhatsAppWebhookEvent[]
  assets                Asset[]
  aiGenerations         AiGeneration[]

  @@index([slug])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Invitation {
  id              String    @id @default(cuid())
  tenantId        String
  email           String
  role            Role
  token           String    @unique
  invitedByUserId String
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@index([token])
}

// ------------------------------------------------------------------
// Models — Phase 2
// ------------------------------------------------------------------

// A person we can market to. Tenant-scoped.
//
// At least one of `email` / `phone` must be set — enforced in the app layer
// (Zod + tRPC mutations) rather than a DB check so we can return nicer
// errors and keep raw SQL inserts flexible for the seed script.
//
// `customFields` is a free-form JSON bag keyed by `CustomField.key`.
// Writes must validate keys against the tenant's CustomField registry
// (app-layer enforcement).
//
// Soft delete via `deletedAt`. Partial unique indexes on (tenantId, email)
// and (tenantId, phone) — see `0002_phase2_audience/migration.sql` — exclude
// soft-deleted rows so a deleted email can be re-added later.
model Contact {
  id             String             @id @default(cuid())
  tenantId       String
  email          String? // lowercase-normalized at write time
  phone          String? // E.164-normalized at write time
  firstName      String?
  lastName       String?
  customFields   Json               @default("{}")
  source         ContactSource      @default(MANUAL)
  emailStatus    SubscriptionStatus @default(SUBSCRIBED)
  smsStatus      SubscriptionStatus @default(SUBSCRIBED)
  whatsappStatus SubscriptionStatus @default(SUBSCRIBED)
  language       String             @default("en")
  timezone       String?
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tags          ContactTag[]
  events        ContactEvent[]
  // Phase 3 — every send to this contact records here
  campaignSends CampaignSend[]
  // Phase 4 — WhatsApp campaign sends + inbox conversations
  whatsAppCampaignSends WhatsAppCampaignSend[]
  whatsAppConversations WhatsAppConversation[]
  // Partial unique indexes on (tenantId, email) and (tenantId, phone) are
  // added via raw SQL in the migration because Prisma 5.22 cannot declare
  // partial indexes in the schema.

  @@index([tenantId, createdAt])
  @@index([tenantId, updatedAt])
  @@index([tenantId, emailStatus])
  @@index([tenantId, smsStatus])
  @@index([tenantId, whatsappStatus])
  @@index([tenantId, deletedAt])
}

model Tag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String // "#RRGGBB"
  createdAt DateTime @default(now())

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts ContactTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

// Defines the schema for `Contact.customFields`. `key` is a slug (e.g.
// "plan_tier", "lifetime_value") unique per tenant. Adding a new field is
// non-destructive. Removing a field strips that key from all contacts'
// `customFields` JSON (app-layer, with a confirmation step). `type` is
// immutable after creation — enforced in the app's update handler.
model CustomField {
  id        String          @id @default(cuid())
  tenantId  String
  key       String
  label     String
  type      CustomFieldType
  options   Json? // { choices: string[] } for SELECT
  createdAt DateTime        @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Segment {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  rules           Json // validated via `segmentRulesSchema` (packages/types)
  cachedCount     Int?
  cachedCountAt   DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("SegmentsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  // Phase 3 — campaigns target a segment
  campaigns Campaign[]

  @@index([tenantId, createdAt])
}

model ImportJob {
  id                    String               @id @default(cuid())
  tenantId              String
  status                ImportJobStatus      @default(PENDING)
  fileName              String
  storagePath           String // "imports/{tenantId}/{id}.csv" in Supabase Storage
  totalRows             Int?
  processedRows         Int                  @default(0)
  successRows           Int                  @default(0)
  errorRows             Int                  @default(0)
  errors                Json                 @default("[]") // capped at 100 entries + { truncated: boolean }
  mapping               Json // { [csvColumn]: { kind: 'field'|'custom_field'|'skip', field?: string, customFieldId?: string } }
  tagIds                String[]
  defaultEmailStatus    SubscriptionStatus   @default(SUBSCRIBED)
  defaultSmsStatus      SubscriptionStatus   @default(SUBSCRIBED)
  defaultWhatsappStatus SubscriptionStatus   @default(SUBSCRIBED)
  dedupeBy              ImportDedupeStrategy @default(EMAIL_OR_PHONE)
  createdByUserId       String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime             @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("ImportsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

// Per-tenant block list keyed on (channel, value). Contacts whose status
// flips to UNSUBSCRIBED/BOUNCED/COMPLAINED get a matching entry auto-created
// at the app layer. The send pipeline (Phase 3) must check this table
// before every send.
//
// Removing an entry here does NOT auto-resubscribe the associated contact —
// that's a separate explicit action (keeps the semantics safe under
// accidental bulk-delete).
model SuppressionEntry {
  id        String            @id @default(cuid())
  tenantId  String
  channel   Channel
  value     String // email: lowercased; phone: E.164
  reason    SuppressionReason
  metadata  Json              @default("{}")
  createdAt DateTime          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, channel, value])
  @@index([tenantId, channel])
}

model ContactEvent {
  id         String           @id @default(cuid())
  tenantId   String
  contactId  String
  type       ContactEventType
  metadata   Json             @default("{}")
  occurredAt DateTime         @default(now())
  createdAt  DateTime         @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId, occurredAt(sort: Desc)])
  @@index([tenantId, type, occurredAt(sort: Desc)])
  @@index([tenantId, occurredAt(sort: Desc)])
}

// ------------------------------------------------------------------
// Models — Phase 3 (email builder, sending, campaign analytics)
// ------------------------------------------------------------------

// A tenant's Resend-verified email sending domain (e.g. "mail.acme.com").
// Created via the tRPC `sendingDomain.create` mutation, which calls Resend's
// domain-create API and stores the returned `resendDomainId` + DNS records.
// Verification is polled via `sendingDomain.verify` (button in the UI) and
// also by a BullMQ repeatable job in apps/worker every 30 minutes for
// PENDING domains.
model SendingDomain {
  id             String              @id @default(cuid())
  tenantId       String
  domain         String
  resendDomainId String?
  status         SendingDomainStatus @default(PENDING)
  verifiedAt     DateTime?
  // Array of { type, name, value, status, priority? } objects — Zod-validated
  // by `sendingDomainSchema` in @getyn/types.
  dnsRecords     Json                @default("[]")
  lastCheckedAt  DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns EmailCampaign[]

  @@unique([tenantId, domain])
  @@index([tenantId, status])
}

// Top-level campaign entity. Phase 3 only implements `type = EMAIL`; the
// enum is widened now so Phase 4 (WhatsApp) and Phase 5 (SMS) reuse this
// row shape without a schema change.
//
// Status transitions:
//   DRAFT  -> SCHEDULED (campaign.schedule)
//   DRAFT  -> SENDING   (campaign.sendNow)
//   SCHEDULED -> SENDING (worker fires at scheduledAt)
//   SENDING -> SENT     (worker marks complete)
//   SCHEDULED -> CANCELED (user cancels before sentAt)
//   SENDING -> PAUSED   (auto on tenant suspension)
//   any -> FAILED       (unrecoverable infra error)
model Campaign {
  id              String         @id @default(cuid())
  tenantId        String
  type            CampaignType   @default(EMAIL)
  name            String
  status          CampaignStatus @default(DRAFT)
  segmentId       String
  scheduledAt     DateTime?
  sentAt          DateTime?
  // Tenant timezone snapshotted at create time, so editing the tenant's TZ
  // later doesn't shift an already-scheduled campaign.
  timezone        String         @default("UTC")
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segment       Segment         @relation(fields: [segmentId], references: [id], onDelete: Restrict)
  createdBy     User?           @relation("CampaignsCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  emailCampaign EmailCampaign?
  // Phase 4 — 1:1 sidecar for type=WHATSAPP campaigns
  whatsAppCampaign WhatsAppCampaign?
  whatsAppCampaignSends WhatsAppCampaignSend[]
  sends         CampaignSend[]
  events        CampaignEvent[]
  trackingLinks TrackingLink[]

  @@index([tenantId, status, scheduledAt])
  @@index([tenantId, createdAt])
}

// 1:1 sidecar of Campaign carrying email-specific fields (subject, design,
// rendered HTML, A/B config). Has no own tenantId — RLS joins through
// Campaign, mirroring the ContactTag pattern from Phase 2.
//
// `renderedHtml` is set when status moves out of DRAFT and is immutable
// after that (enforced in tRPC + a defensive trigger added in the
// migration). Mid-flight edits would mean recipients in the same campaign
// got different content.
model EmailCampaign {
  id              String  @id @default(cuid())
  campaignId      String  @unique
  subject         String
  previewText     String?
  fromName        String
  fromEmail       String
  replyTo         String?
  sendingDomainId String?
  // Unlayer's design payload — the single source of truth for the editor.
  designJson      Json
  // Flattened HTML at send time. Text columns to support large emails.
  renderedHtml    String? @db.Text
  // Auto-generated plaintext alternative via html-to-text. Required for
  // RFC-compliant multipart/alternative emails.
  renderedText    String? @db.Text
  // Zod-validated by `abTestSchema` in @getyn/types. Null when A/B is off.
  abTest          Json?
  templateId      String?

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sendingDomain SendingDomain? @relation(fields: [sendingDomainId], references: [id], onDelete: SetNull)
  template      EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

// System templates have `tenantId = null` and are read-only to every tenant.
// Tenant-owned templates have `tenantId` set and follow the standard RLS
// pattern. The migration adds two RLS policies (one for each case).
model EmailTemplate {
  id              String                @id @default(cuid())
  tenantId        String? // NULL = system template
  name            String
  description     String?
  category        EmailTemplateCategory @default(OTHER)
  thumbnailUrl    String?
  designJson      Json
  createdByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant    Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("EmailTemplatesCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  campaigns EmailCampaign[]

  @@index([tenantId, category])
  @@index([tenantId, createdAt])
}

// One row per (campaign, recipient). The unit of dispatch + tracking.
// Created in bulk by the `prepare-campaign` BullMQ job; updated by the
// `dispatch-batch` worker (status = SENT) and webhook handler
// (DELIVERED/OPENED/CLICKED/BOUNCED/COMPLAINED).
//
// `email` is a snapshot at queue time — we never look up the contact
// again after queueing. If the contact's email changes mid-send, the
// already-queued sends still go to the original address.
//
// `messageId` is Resend's globally unique id; webhook lookups use it.
model CampaignSend {
  id           String             @id @default(cuid())
  tenantId     String
  campaignId   String
  contactId    String
  email        String
  messageId    String?            @unique
  status       CampaignSendStatus @default(QUEUED)
  abVariant    AbVariant?
  sentAt       DateTime?
  lastEventAt  DateTime?
  errorMessage String?

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  events   CampaignEvent[]

  @@index([tenantId, campaignId, status])
  @@index([tenantId, contactId])
}

// Append-only time-series of every send outcome. The webhook handler
// inserts here; analytics queries this table for the time-series chart
// (real-time numbers come from CampaignSend.status aggregates instead —
// see M8).
//
// `metadata` is JSON, validated per-type by Zod schemas in @getyn/types
// (`campaignEventMetadataSchemas`). Stored unstructured for forward
// compatibility with new Resend event fields.
model CampaignEvent {
  id             String            @id @default(cuid())
  tenantId       String
  campaignSendId String
  // Direct denormalized link to Campaign for analytics queries — avoids a
  // JOIN through CampaignSend on every dashboard render. The cascade
  // through campaignSendId already handles real deletion; this FK is just
  // for direct lookups, hence `SetNull` to avoid double-cascade conflict.
  campaignId     String?
  type           CampaignEventType
  metadata       Json              @default("{}")
  occurredAt     DateTime          @default(now())
  createdAt      DateTime          @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignSend CampaignSend @relation(fields: [campaignSendId], references: [id], onDelete: Cascade)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([tenantId, campaignSendId, occurredAt(sort: Desc)])
  @@index([tenantId, type, occurredAt(sort: Desc)])
  @@index([tenantId, campaignId, occurredAt(sort: Desc)])
}

// Short-link table powering /r/{slug} click tracking. Link-rewriting
// happens at dispatch time: the renderer scans the email HTML, replaces
// every `<a href>` with `/r/{slug}` after creating a TrackingLink row.
//
// `slug` is 8-char base62 (~218T combos), generated via nanoid.
// Collision-on-insert retry up to 3x in code.
//
// `clickCount` is denormalized for fast top-links queries; the source of
// truth is CampaignEvent rows of type CLICKED.
model TrackingLink {
  id          String   @id @default(cuid())
  tenantId    String
  campaignId  String
  originalUrl String
  slug        String   @unique
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([tenantId, campaignId])
}

// Per-tenant deliverability guardrails + plan-driven limits. One row per
// tenant, auto-created by the `0003_phase3_email` migration backfill.
//
// `currentDailyCount` resets via a BullMQ repeatable job at 00:00 UTC.
// `cached*30d` aggregates are updated incrementally by the webhook
// handler on every bounce/complaint event, and recomputed from raw
// CampaignEvent rows by an hourly drift-correction job (see M6 pushback
// item #4 in the kickoff). `dispatch-batch` reads the cached values
// only — never aggregates raw events at send time.
//
// `suspendedAt` is set automatically when a rate exceeds threshold; the
// UI shows a banner; new sends are rejected until OWNER manually clears
// the suspension via the runbook (see apps/worker/README.md).
model TenantSendingPolicy {
  id                     String    @id @default(cuid())
  tenantId               String    @unique
  // Defaults overridden in the migration backfill based on plan.
  dailySendLimit         Int       @default(200)
  complaintRateThreshold Float     @default(0.003)
  bounceRateThreshold    Float     @default(0.05)
  currentDailyCount      Int       @default(0)
  lastResetAt            DateTime  @default(now())
  cachedComplaintRate30d Float     @default(0)
  cachedBounceRate30d    Float     @default(0)
  cachedSendCount30d     Int       @default(0)
  cachedRatesUpdatedAt   DateTime  @default(now())
  suspendedAt            DateTime?
  suspensionReason       String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ==================================================================
// Phase 4 — WhatsApp Business
// ==================================================================
//
// BYOC model: each tenant brings their own WhatsApp Business Account
// (WABA). We store an encrypted system-user access token (see
// @getyn/crypto). Templates are authored in our UI, submitted to Meta,
// status polled back. Outbound campaign status uses 2-minute Graph API
// polling; inbound messages use webhooks with a 5-minute poll fallback.
//
// Core dual-write rule: outbound campaign messages create BOTH a
// WhatsAppCampaignSend (analytics source of truth) and a
// WhatsAppMessage (inbox source of truth) in the dispatch transaction.
// Status updates from polling/webhooks update both by metaMessageId.
// They are siblings — no FK between them — linked by string match.

// ------------------------------------------------------------------
// Enums — Phase 4
// ------------------------------------------------------------------

enum WAStatus {
  PENDING
  CONNECTED
  DISCONNECTED
  SUSPENDED
}

enum WAQualityRating {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

// Meta's messaging tier — determines unique-recipient cap per 24h.
// Newly registered numbers start at TIER_50; Meta auto-promotes based
// on quality + volume.
enum WAMessagingTier {
  TIER_50
  TIER_250
  TIER_1K
  TIER_10K
  TIER_100K
  TIER_UNLIMITED
}

enum WADisplayPhoneStatus {
  CONNECTED
  PENDING_REVIEW
  DISCONNECTED
  FLAGGED
}

enum WATemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum WATemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

// Per-message pricing category from Meta. Different from template
// category — Meta may reclassify based on actual content/intent.
enum WAPricingCategory {
  AUTHENTICATION
  MARKETING
  UTILITY
  SERVICE
}

enum WASendStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  SUPPRESSED
}

enum WAMessageDirection {
  INBOUND
  OUTBOUND
}

enum WAMessageType {
  TEXT
  TEMPLATE
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  STICKER
  LOCATION
  CONTACT
  INTERACTIVE_BUTTON
  INTERACTIVE_LIST
  REACTION
  UNSUPPORTED
}

enum WAConversationStatus {
  OPEN
  CLOSED
}

// ------------------------------------------------------------------
// Models — Phase 4
// ------------------------------------------------------------------

// One WABA per tenant in MVP (see kickoff #4 pushback). The unique
// constraint on tenantId enforces this. Multi-WABA per tenant
// (multi-brand companies) is a future migration.
//
// `accessTokenEncrypted` is a Json column carrying the @getyn/crypto
// EncryptedField shape: { ciphertext, iv, authTag, keyVersion }.
// Encrypted with tenantId as associated data so a row stolen out of
// tenant A's account into tenant B fails authentication.
model WhatsAppAccount {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  wabaId               String    // Meta's Business Account ID
  displayName          String
  status               WAStatus  @default(PENDING)
  connectedAt          DateTime?
  disconnectedAt       DateTime?
  accessTokenEncrypted Json      // EncryptedField from @getyn/crypto, AD=tenantId
  tokenExpiresAt       DateTime? // null for system-user tokens that don't expire
  appId                String    // Meta App ID used for connection (M3 manual or M11 embedded)
  metadata             Json      @default("{}") // business verification status, country, currency
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumbers WhatsAppPhoneNumber[]
  templates    WhatsAppTemplate[]
  campaigns    WhatsAppCampaign[]
  conversations WhatsAppConversation[]

  @@index([tenantId])
  @@index([wabaId])
}

// One per phone number registered to the WABA. A tenant typically has
// one (e.g. customer-support hotline) but Meta allows up to 25.
//
// `currentTier24hUsage` + `tier24hWindowResetAt` are best-effort local
// counters refreshed by the wa-phone-refresh cron from Meta's API
// (M4). The 24h window starts at first send, NOT at midnight UTC.
model WhatsAppPhoneNumber {
  id                          String               @id @default(cuid())
  tenantId                    String
  whatsAppAccountId           String
  phoneNumberId               String               // Meta's phone_number_id
  phoneNumber                 String               // E.164 display, e.g. +14155551234
  verifiedName                String
  qualityRating               WAQualityRating      @default(UNKNOWN)
  messagingTier               WAMessagingTier      @default(TIER_50)
  currentTier24hUsage         Int                  @default(0)
  tier24hWindowResetAt        DateTime?
  displayPhoneNumberStatus    WADisplayPhoneStatus @default(PENDING_REVIEW)
  pinSetAt                    DateTime?            // 2FA PIN required for sending
  metadata                    Json                 @default("{}")
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount     @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  campaigns       WhatsAppCampaign[]
  conversations   WhatsAppConversation[]

  @@unique([tenantId, phoneNumberId])
  @@index([whatsAppAccountId])
}

// In-app authored OR synced from Meta. `metaTemplateId` is null for
// drafts not yet submitted; sync (M5) backfills it when Meta reports
// the template under the same (name, language). Soft-deleted via
// `deletedAt`; the partial unique index in 0004 migration excludes
// deleted rows so a tenant can recreate same-name templates.
//
// `components` is a Json array matching Meta's API exactly — see
// templateComponentsSchema in @getyn/types. We submit it directly.
model WhatsAppTemplate {
  id                String             @id @default(cuid())
  tenantId          String
  whatsAppAccountId String
  metaTemplateId    String?            // null until submitted to Meta
  name              String             // slug, lowercase + underscores per Meta
  language          String             // e.g. en_US, hi, es
  category          WATemplateCategory
  status            WATemplateStatus   @default(DRAFT)
  rejectionReason   String?            @db.Text
  components        Json               // TemplateComponent[] — see @getyn/types
  qualityRating     WAQualityRating    @default(UNKNOWN)
  lastSyncedAt      DateTime?
  submittedAt       DateTime?
  approvedAt        DateTime?
  createdByUserId   String?
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount    @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  createdBy       User?              @relation("WhatsAppTemplatesCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  campaigns       WhatsAppCampaign[]
  messages        WhatsAppMessage[]

  // Partial unique index (whatsAppAccountId, name, language) WHERE
  // deletedAt IS NULL — added in 0004 migration (Prisma can't express
  // partial uniques in the schema).
  @@index([tenantId, status])
  @@index([whatsAppAccountId, status])
}

// 1:1 sidecar of Campaign for type=WHATSAPP. Mirrors EmailCampaign.
// `templateVariables` is a Json array of { type, value | merge_tag }
// resolved per-recipient at dispatch time.
model WhatsAppCampaign {
  id                  String  @id @default(cuid())
  campaignId          String  @unique
  whatsAppAccountId   String
  phoneNumberId       String
  templateId          String
  templateLanguage    String
  templateVariables   Json    // resolved per-recipient at dispatch
  headerMediaAssetId  String?

  campaign         Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  whatsAppAccount  WhatsAppAccount     @relation(fields: [whatsAppAccountId], references: [id], onDelete: Restrict)
  phoneNumber      WhatsAppPhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Restrict)
  template         WhatsAppTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  headerMediaAsset Asset?              @relation(fields: [headerMediaAssetId], references: [id], onDelete: SetNull)
}

// Per-recipient send record. Mirrors CampaignSend (Phase 3) for
// analytics. The dispatch handler creates this AND a WhatsAppMessage
// row atomically so the inbox renders campaign messages alongside
// free-form replies.
model WhatsAppCampaignSend {
  id                String             @id @default(cuid())
  tenantId          String
  campaignId        String
  contactId         String
  phone             String             // E.164 snapshot at queue time
  metaMessageId     String?            // null until dispatched; unique per tenant once set
  status            WASendStatus       @default(QUEUED)
  pricingCategory   WAPricingCategory? // Meta's per-message pricing classification
  conversationId    String?            // Meta's conversation ID (24h window grouping)
  errorCode         String?
  errorMessage      String?            @db.Text
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  lastEventAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, metaMessageId])
  @@index([tenantId, campaignId, status])
  @@index([tenantId, status, createdAt])
}

// Inbox conversation. Identified per tenant by (phoneNumberId, contactPhone).
// `serviceWindowExpiresAt` is set/extended ONLY on inbound messages
// (24h forward); outbound replies do NOT extend it (this is Meta's rule).
// `unreadCount` updated atomically via SQL increment, never read-modify-write.
model WhatsAppConversation {
  id                     String              @id @default(cuid())
  tenantId               String
  whatsAppAccountId      String
  phoneNumberId          String
  contactId              String?             // null for inbound from unknown numbers, until matched
  contactPhone           String              // E.164
  lastInboundAt          DateTime?
  lastOutboundAt         DateTime?
  lastMessageAt          DateTime            @default(now())
  lastMessagePreview     String              @default("") @db.Text
  unreadCount            Int                 @default(0)
  assignedToUserId       String?
  serviceWindowExpiresAt DateTime?           // null = window closed; only template messages allowed
  status                 WAConversationStatus @default(OPEN)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  whatsAppAccount WhatsAppAccount     @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  phoneNumber     WhatsAppPhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  contact         Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo      User?               @relation("WhatsAppConversationsAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages        WhatsAppMessage[]

  @@unique([tenantId, phoneNumberId, contactPhone])
  @@index([tenantId, lastMessageAt])
  @@index([tenantId, status, lastMessageAt])
  @@index([tenantId, assignedToUserId, lastMessageAt])
}

// Every inbound + outbound message in the inbox. Outbound campaign
// messages also land here (dual write with WhatsAppCampaignSend).
//
// `metaMessageId` is unique per tenant — used by the webhook /
// poll-status handlers to dedupe and update status. `replyToMessageId`
// is a self-FK for quoted replies.
model WhatsAppMessage {
  id                String              @id @default(cuid())
  tenantId          String
  conversationId    String
  direction         WAMessageDirection
  metaMessageId     String?             // unique per tenant once set
  type              WAMessageType
  body              String?             @db.Text // text body; caption for media; null for non-text
  mediaAssetId      String?             // resolved Asset for media messages
  mediaMetaId       String?             // Meta's media id, used for delayed download
  templateId        String?             // for outbound TEMPLATE messages
  templateVariables Json?               // resolved variables at send time
  status            WASendStatus        @default(QUEUED)
  errorCode         String?
  errorMessage      String?             @db.Text
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failedAt          DateTime?
  sentByUserId      String?             // for free-form replies sent from inbox UI
  replyToMessageId  String?             // self-FK
  metadata          Json                @default("{}")
  createdAt         DateTime            @default(now())

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation WhatsAppConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  template     WhatsAppTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  mediaAsset   Asset?                @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  sentBy       User?                 @relation("WhatsAppMessagesSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)
  replyTo      WhatsAppMessage?      @relation("WhatsAppMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies      WhatsAppMessage[]     @relation("WhatsAppMessageReplies")

  @@index([conversationId, createdAt])
  @@index([tenantId, metaMessageId])
}

// Raw event log for idempotency + debugging. The webhook receiver
// upserts on `dedupeKey` (computed from event kind + metaMessageId +
// status, see kickoff pushback #1). Successful processing sets
// `processedAt`; failure stamps `processError` for retry.
model WhatsAppWebhookEvent {
  id            String    @id @default(cuid())
  tenantId      String?   // null until matched (e.g. unknown WABA hits us)
  phoneNumberId String?   // null until matched
  eventType     String    // 'inbound' | 'status:sent' | 'status:delivered' | etc.
  dedupeKey     String    @unique
  rawPayload    Json
  processedAt   DateTime?
  processError  String?   @db.Text
  receivedAt    DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, receivedAt])
  @@index([eventType, processedAt])
}

// Generic media table. Used by template media headers, inbox media
// messages, and future asset-bearing features. Storage path lives
// under tenants/<tenantId>/wa-assets/<id>.<ext> in the wa-assets
// bucket (private, signed URLs only).
model Asset {
  id                  String   @id @default(cuid())
  tenantId            String
  fileName            String
  mimeType            String
  sizeBytes           Int
  storagePath         String   // tenants/<tenantId>/wa-assets/<id>.<ext>
  mediaMetaId         String?  // Meta's media id, populated after upload to Meta
  uploadedByUserId    String?
  createdAt           DateTime @default(now())

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy User?              @relation("AssetsUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  templateMessages   WhatsAppMessage[]
  campaignsAsHeader  WhatsAppCampaign[]

  @@index([tenantId, createdAt])
}

// AI generation audit log. Phase 4 M7 introduces the first AI feature
// (template drafting). Phase 5 will expand this with per-feature
// rate limits / cost rollups.
model AiGeneration {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  feature     String   // 'wa_template_draft' for now; enum in Phase 5
  prompt      String   @db.Text
  response    String   @db.Text
  tokensUsed  Int
  cost        Decimal  @db.Decimal(10, 4) // USD; sub-cent precision for token-cost rollups
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, feature, createdAt])
}
