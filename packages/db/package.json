{
  "name": "@getyn/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push && pnpm db:rls",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy && pnpm db:rls",
    "db:studio": "prisma studio",
    "db:rls": "tsx scripts/apply-rls.ts",
    "db:rls:verify": "tsx scripts/verify-rls.ts",
    "db:seed": "tsx prisma/seed.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules/.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@getyn/types": "workspace:*",
    "@prisma/client": "^5.19.1"
  },
  "devDependencies": {
    "@getyn/config": "workspace:*",
    "@types/node": "^20.16.10",
    "eslint": "^8.57.1",
    "prisma": "^5.19.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
